      "destination": "/blog/devis-dentaire-dakar-comprendre-tarifs",
      "permanent": true
    },
    {
      "source": "/blog/gingivite-causes-symptomes-traitement",
      "destination": "/blog/gencives-qui-saignent-gingivite-dakar",
      "permanent": true
    },
    {
      "source": "/blog/detartrage-dentaire-dakar-prix-frequence-bon-timing-2026",
      "destination": "/blog/detartrage-dentaire-dakar-prix-frequence",
      "permanent": true
    },
    {
      "source": "/blog/prix-appareil-dentaire-dakar-guide-complet-2025-2026",
      "destination": "/blog/appareil-dentaire-prix-dakar-guide-complet",
      "permanent": true
    },
    {
      "source": "/blog/orthodontie-adulte-dakar-quel-appareil-choisir",
