    },
    {
      "source": "/blog/remede-rage-de-dent-quoi-faire-immédiatement",
      "destination": "/blog/mal-de-dents-la-nuit-causes-et-que-faire",
      "permanent": true
    },
    {
      "source": "/blog/remede-rage-de-dent-quoi-faire-immediatement",
      "destination": "/blog/mal-de-dents-la-nuit-causes-et-que-faire",
      "permanent": true
    }
  ],
  "rewrites": [
